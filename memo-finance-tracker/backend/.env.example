# Copy this file to .env and adjust values as needed.

# SQLite (default for local dev)
DATABASE_URL=sqlite:///./ha_budgeting.db

# For PostgreSQL (production example):
# DATABASE_URL=postgresql://user:password@localhost:5432/ha_budgeting

APP_ENV=development

# ---------------------------------------------------------------------------
# MQTT Discovery (optional)
# Leave MQTT_HOST empty to disable. When set, MEMO publishes its metrics as
# Home Assistant sensors via MQTT Discovery (requires a Mosquitto/MQTT broker).
# ---------------------------------------------------------------------------
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Base MQTT topic + HA discovery prefix (defaults shown)
MQTT_BASE_TOPIC=memo
MQTT_DISCOVERY_PREFIX=homeassistant
# Currency unit used for monetary sensors, and publish interval in seconds
MQTT_CURRENCY=€
MQTT_PUBLISH_INTERVAL=300
